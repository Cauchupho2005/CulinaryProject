@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@inject NavigationManager NavManager

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />


@if (_isAuthenticated)
{
    <MudLayout>
        @* Thanh Header bên trên *@
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            <MudText Typo="Typo.h6" Class="ml-3">Culinary Admin</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
        </MudAppBar>

        @* Thanh Menu bên trái *@
        <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
            <NavMenu />
        </MudDrawer>

        @* Phần nội dung chính ở giữa *@
        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}
else
{
    @* Màn hình chờ trong tích tắc lúc bảo vệ đang check thẻ *@
    <MudContainer Class="d-flex align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Class="ml-4">Đang kiểm tra quyền truy cập...</MudText>
    </MudContainer>
}

@code {
    // ==========================================
    // 1. BIẾN CỦA GIAO DIỆN CŨ (Đóng/mở Menu)
    // ==========================================
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    // ==========================================
    // 2. BIẾN BẢO MẬT MỚI (Kiểm tra Đăng nhập)
    // ==========================================
    private bool _isAuthenticated = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Lấy thẻ tên "userRole" từ bộ nhớ trình duyệt
            var result = await SessionStorage.GetAsync<string>("userRole");

            // Nếu không có thẻ hoặc thẻ rỗng (Chưa đăng nhập)
            if (!result.Success || string.IsNullOrEmpty(result.Value))
            {
                // Đá văng ra cửa Login
                NavManager.NavigateTo("/login");
            }
            else
            {
                // Có thẻ hợp lệ -> Cho phép hiển thị khung MainLayout
                _isAuthenticated = true;
                StateHasChanged(); // Ép hệ thống vẽ lại giao diện
            }
        }
    }
}