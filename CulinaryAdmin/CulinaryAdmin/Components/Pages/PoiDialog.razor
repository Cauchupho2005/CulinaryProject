@using CulinaryAdmin.Models
@using MudBlazor
@inject ISnackbar Snackbar
@inject HttpClient Http

<MudDialog>
    <DialogContent>
        <MudForm Model="@PoiData" @ref="_form" IsValid="@_success" ValidationDelay="0">
            <MudGrid>
                @* Hàng 1: Tên và Địa chỉ *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="PoiData.Title" For="@(() => PoiData.Title)" Label="Tên quán (*)" Variant="Variant.Outlined" Clearable="true" Placeholder="Nhập tên quán..." />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="PoiData.Address" For="@(() => PoiData.Address)" Label="Địa chỉ (*)" Variant="Variant.Outlined" Clearable="true" Placeholder="Nhập địa chỉ..." />
                </MudItem>

                @* Hàng 2: Mô tả *@
                <MudItem xs="12">
                    <MudTextField @bind-Value="PoiData.Description" For="@(() => PoiData.Description)" Label="Mô tả quán ăn (*)" Lines="3" Variant="Variant.Outlined" Clearable="true" Placeholder="Nhập mô tả..." />
                </MudItem>

                @* Hàng 3: Nút Upload ảnh *@
                <MudItem xs="12">
                    <MudFileUpload T="IBrowserFile" FilesChanged="UploadImage">
                        <ActivatorContent>
                            <MudButton HtmlTag="label"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload">
                                Tải ảnh lên từ máy tính
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    
                    @* Hiển thị ảnh xem trước (Preview) nếu đã upload thành công *@
                    @if (!string.IsNullOrWhiteSpace(PoiData.CoverImageUrl))
                    {
                        <div class="mt-3">
                            <MudImage Src="@(PoiData.CoverImageUrl.StartsWith("/") ? $"http://10.192.152.134:5000{PoiData.CoverImageUrl}" : PoiData.CoverImageUrl)"
                                      Width="200" ObjectFit="ObjectFit.Cover" Class="rounded-lg elevation-2" />
                            <MudText Typo="Typo.caption" Color="Color.Success" Class="d-block mt-1">✓ Đã đính kèm ảnh thành công</MudText>
                        </div>
                    }
                </MudItem>

                @* Hàng 4: Tọa độ bản đồ (Kinh độ - Longitude, Vĩ độ - Latitude) *@
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="Longitude" Label="Kinh độ (Longitude)" Variant="Variant.Outlined" HideSpinButtons="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="Latitude" Label="Vĩ độ (Latitude)" Variant="Variant.Outlined" HideSpinButtons="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">LƯU DỮ LIỆU</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // 1. Đã thêm chữ 'I' vào IMudDialogInstance
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter] public PoiModel PoiData { get; set; } = new PoiModel();

    // 2. Thêm '= null!' để dọn sạch cảnh báo CS8618
    private MudForm _form = null!;
    private bool _success;

    private double Longitude
    {
        get => PoiData.Location?.Coordinates[0] ?? 0;
        set
        {
            if (PoiData.Location == null) PoiData.Location = new GeoLocation();
            PoiData.Location.Coordinates[0] = value;
        }
    }

    private double Latitude
    {
        get => PoiData.Location?.Coordinates[1] ?? 0;
        set
        {
            if (PoiData.Location == null) PoiData.Location = new GeoLocation();
            PoiData.Location.Coordinates[1] = value;
        }
    }

    // Class phụ để hứng dữ liệu JSON trả về từ API { "url": "/images/poi/..." }
    private class UploadResponse
    {
        public string url { get; set; } = "";
    }

    private async Task UploadImage(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            Snackbar.Add("Đang tải ảnh lên...", Severity.Info);

            // Đóng gói file thành định dạng MultipartFormData để gửi lên Backend
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(10 * 1024 * 1024)); // Cho phép ảnh nặng tối đa 10MB
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            // Bắn file lên API Upload của Sếp
            var response = await Http.PostAsync("api/Poi/upload-image", content);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                if (result != null && !string.IsNullOrEmpty(result.url))
                {
                    // Lấy cái "biên lai" (đường dẫn tương đối) nhét vào dữ liệu Quán ăn
                    PoiData.CoverImageUrl = result.url;
                    Snackbar.Add("Tải ảnh lên thành công!", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add("Lỗi khi lưu ảnh vào server.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
    
        await _form.ValidateAsync();
        
        if (_form.IsValid)
        {
            MudDialog.Close(DialogResult.Ok(PoiData));
        }
    }
}