@page "/pois"
@using CulinaryAdmin.Models
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@rendermode InteractiveServer

<MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-4">Quản lý POI (Điểm đến) & Phân hạng VIP</MudText>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

@if (_pois == null)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">Đang tải danh sách quán ăn...</MudText>
}
else
{
    <MudTable Items="@_pois" Hover="true" Striped="true" Dense="true" Filter="new Func<PoiModel, bool>(FilterFunction)">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Danh sách POI (@_pois.Count địa điểm)</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Tìm tên, địa chỉ hoặc hạng (Kim cương, Vàng...)"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Hình ảnh</MudTh>
            <MudTh>Tên POI</MudTh>
            <MudTh>Địa chỉ</MudTh>
            <MudTh>Thứ hạng (Rank)</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh Style="text-align: center;">Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Hình ảnh">
                <MudImage Src="@(string.IsNullOrEmpty(context.CoverImageUrl) ? "images/no-image.png" : context.CoverImageUrl)"
                          Alt="@context.Title" Height="50" Width="80" ObjectFit="ObjectFit.Cover" Class="rounded" />
            </MudTd>
            <MudTd DataLabel="Tên POI"><b>@context.Title</b></MudTd>
            <MudTd DataLabel="Địa chỉ">@context.Address</MudTd>
            <MudTd DataLabel="Thứ hạng">
                @switch (context.Rank)
                {
                    case 4:
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.Star">KIM CƯƠNG</MudChip>
                        break;
                    case 3:
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.ThumbUp">BẠCH KIM</MudChip>
                        break;
                    case 2:
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.Grade">VÀNG</MudChip>
                        break;
                    case 1:
                        <MudChip T="string" Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">BẠC</MudChip>
                        break;
                    default:
                        <MudText Typo="Typo.body2" Class="ml-2" Color="Color.Default">🥉 Đồng (Free)</MudText>
                        break;
                }
            </MudTd>
            <MudTd DataLabel="Trạng thái">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Text">
                    @GetStatusText(context.Status)
                </MudChip>
            </MudTd>
            <MudTd Style="text-align: center;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small"
                               OnClick="@(() => EditPoi(context))" Title="Chỉnh sửa / Nâng cấp Rank" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeletePoi(context))" Title="Xóa quán" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager InfoFormat="{first_item}-{last_item} trong {all_items}" RowsPerPageString="Dòng mỗi trang:" />
        </PagerContent>
    </MudTable>
}

@code {
    private List<PoiModel> _pois = new();
    private bool _isLoading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadPois();
    }

    private async Task LoadPois()
    {
        _isLoading = true;
        try
        {
            _pois = await Http.GetFromJsonAsync<List<PoiModel>>("api/Poi");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool FilterFunction(PoiModel poi)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        string rankName = poi.Rank switch
        {
            4 => "kim cương diamond vip4",
            3 => "bạch kim platinum vip3",
            2 => "vàng gold vip2",
            1 => "bạc silver vip1",
            _ => "đồng bronze free"
        };

        if (poi.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (poi.Address != null && poi.Address.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (rankName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;

        return false;
    }

    private async Task EditPoi(PoiModel poi)
    {
        // 1. Clone dữ liệu để tránh sửa trực tiếp vào bảng khi chưa nhấn Lưu
        var parameters = new DialogParameters
        {
            ["PoiData"] = new PoiModel
            {
                Id = poi.Id,
                Title = poi.Title,
                Address = poi.Address,
                Description = poi.Description,
                CoverImageUrl = poi.CoverImageUrl,
                Rank = poi.Rank, // Truyền hạng hiện tại vào Dialog
                OwnerId = poi.OwnerId,
                Status = poi.Status,
                Location = poi.Location == null ? null : new GeoLocation
                {
                    Type = poi.Location.Type,
                    Coordinates = (double[])poi.Location.Coordinates.Clone()
                }
            }
        };
        
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        // 2. Mở Dialog PoiDialog (đã fix tên Component chuẩn của bạn)
        var dialog = await DialogService.ShowAsync<PoiDialog>("Chỉnh sửa & Nâng cấp Rank", parameters, options);
        var result = await dialog.Result;

        // 3. Nếu người dùng nhấn Lưu, gọi API cập nhật xuống Backend
        if (!result.Canceled)
        {
            var updatedPoi = (PoiModel)result.Data;
            try
            {
                var response = await Http.PutAsJsonAsync($"api/Poi/{poi.Id}", updatedPoi);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Đã cập nhật quán '{poi.Title}' thành công!", Severity.Success);
                    await LoadPois(); // Tải lại danh sách
                }
                else
                {
                    Snackbar.Add("Lỗi khi cập nhật dữ liệu lên Server!", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi hệ thống: {ex.Message}", Severity.Error);
            }
        }
    }

    private Color GetStatusColor(string? status) => status switch
    {
        "approved" => Color.Success,
        "pending" => Color.Warning,
        "rejected" => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(string? status) => status switch
    {
        "approved" => "Đã duyệt",
        "pending" => "Chờ duyệt",
        "rejected" => "Từ chối",
        "deleted" => "Đã xóa",
        _ => "Không rõ"
    };

    private async Task DeletePoi(PoiModel poi)
    {
        var parameters = new DialogParameters();
        parameters.Add("ContentText", $"Bạn có chắc muốn xoá quán '{poi.Title}' không?");
        parameters.Add("ButtonText", "Xoá");
        parameters.Add("Color", Color.Error);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Xác nhận xoá", parameters, options);
        var dialogResult = await dialog.Result;

        if (!dialogResult.Canceled)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Poi/{poi.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã xoá thành công!", Severity.Success);
                    await LoadPois();
                }
                else
                {
                    Snackbar.Add("Lỗi khi xoá!", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            }
        }
    }
}