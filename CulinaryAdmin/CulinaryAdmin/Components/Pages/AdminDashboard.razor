@page "/admin-dashboard"
@attribute [Authorize(Roles = "admin")]
@using CulinaryAdmin.Models
@using System.Timers
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6"><b>Tổng quan hệ thống</b></MudText>

    @* 1. HÀNG THẺ THỐNG KÊ (KPI CARDS) *@
    <MudGrid Class="mb-6">
        @* Thẻ Active Users (Mới trộn vào) *@
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Elevation="4" Class="pa-4 d-flex align-center mud-theme-primary">
                <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.body2">Online</MudText>
                    <MudText Typo="Typo.h5"><b>@activeUserCount</b></MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="2">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Tổng Quán</MudText>
                    @if (_isLoading)
                    {
                        <MudSkeleton Width="40px" />
                    }
                    else
                    {

                        <MudText Typo="Typo.h5"><b>@_poiCount</b></MudText>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="2">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Info" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Admin</MudText>
                    <MudText Typo="Typo.h5"><b>@_userCount</b></MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Chủ quán (Owner)</MudText>
                    <MudText Typo="Typo.h5"><b>@_ownerCount</b></MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.LockPerson" Color="Color.Warning" Size="Size.Large" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">TK bị khoá</MudText>
                    <MudText Typo="Typo.h5"><b>@_lockedCount</b></MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* 2. THỐNG KÊ BIỂU ĐỒ & ĐĂNG KÝ *@
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader><MudText Typo="Typo.h6">Phân bổ Danh mục Quán ăn</MudText></MudCardHeader>
                <MudCardContent>
                    @if (_categoryStats.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">Chưa có dữ liệu.</MudAlert>
                    }
                    else
                    {
                        @foreach (var item in _categoryStats)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
                                <MudText Typo="Typo.body2">@item.Label</MudText>
                                <MudChip T="int" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@item.Count</MudChip>
                            </MudStack>
                            <MudProgressLinear Color="Color.Primary" Value="@GetCategoryPercent(item.Count)" Class="mb-3" />
                        }
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        

        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader><MudText Typo="Typo.h6">Lượt đăng ký mới (7 ngày)</MudText></MudCardHeader>
                <MudCardContent>
                    <MudTable Items="_userRegistrations" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Ngày</MudTh>
                            <MudTh style="text-align:right;">Số lượng</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Day</MudTd>
                            <MudTd style="text-align:right;"><MudChip T="int" Size="Size.Small" Color="Color.Info">@context.Count</MudChip></MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mb-6 mt-4">
        <MudItem xs="12">
            <MudPaper Elevation="3" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Bản đồ Phân bổ Mật độ User (Heatmap)</MudText>
                <div id="admin-heatmap" style="height: 500px; width: 100%; border-radius: 10px; z-index: 1;"></div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* 3. THỐNG KÊ TRUY CẬP *@
    <MudPaper Elevation="1" Class="pa-4 my-6" Style="background: #f8fafc; border: 1px solid #e2e8f0;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">Hoạt động & Logs</MudText>
            <MudStack Row="true">
                <MudChip T="string" Color="Color.Error" Variant="Variant.Outlined">Logs: @_totalLogs</MudChip>
                <MudChip T="string" Color="Color.Info">Tổng truy cập: @_totalVisits</MudChip>
                <MudButton StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadVisitStats">Làm mới</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.h6" Class="mb-3">Top quán được quan tâm</MudText>
    <MudPaper Elevation="2">
        <MudTable Items="_visitStats" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Top</MudTh>
                <MudTh>Tên Quán</MudTh>
                <MudTh style="text-align:right;">Lượt xem</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">#@(_visitStats.IndexOf(context) + 1)</MudChip></MudTd>
                <MudTd>@context.PoiTitle</MudTd>
                <MudTd style="text-align:right;"><b>@context.TotalVisits</b></MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private bool _isLoading = true;
    private int _poiCount, _userCount, _ownerCount, _lockedCount, _totalVisits, _totalLogs;
    private int activeUserCount = 0;
    private Timer? _timer;

    private List<PoiVisitStatsModel> _visitStats = new();
    private List<string> _otherCategoryPois = new();
    private List<(string Label, int Count)> _categoryStats = new();
    private List<(string Day, int Count)> _userRegistrations = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStaticData(); // Tải dữ liệu thống kê chung
        
        // Thiết lập Timer cập nhật Active Users mỗi 5 giây
        await FetchActiveUsers();
        await FetchHeatmapData(); // <-- BỔ SUNG: Vẽ Heatmap ngay lần đầu mở trang

        _timer = new Timer(5000);
        _timer.Elapsed += async (s, e) => await OnTimerElapsed();
        _timer.AutoReset = true;
        _timer.Start();
    }

    private async Task LoadStaticData()
    {
        try
        {
            _isLoading = true;
            var poisTask = Http.GetFromJsonAsync<List<PoiModel>>("api/Poi?lang=vi&includeDeleted=true");
            var usersTask = Http.GetFromJsonAsync<List<UserAdminModel>>("api/User");
            var logsTask = Http.GetFromJsonAsync<List<object>>("api/Log");

            await Task.WhenAll(poisTask, usersTask, logsTask);

            var pois = poisTask.Result ?? new();
            var users = usersTask.Result ?? new();
            
            _poiCount = pois.Count;
            _userCount = users.Count(u => u.Role == "admin");
            _ownerCount = users.Count(u => u.Role == "poi_owner");
            _lockedCount = users.Count(u => !u.IsActive);
            _totalLogs = logsTask.Result?.Count ?? 0;

            // Phân loại Category
            ProcessCategories(pois);

            // Thống kê đăng ký 7 ngày
            var today = DateTime.UtcNow.Date;
            _userRegistrations = Enumerable.Range(0, 7).Select(i =>
            {
                var day = today.AddDays(-6 + i);
                return (day.ToString("dd/MM"), users.Count(u => u.CreatedAt.Date == day));
            }).ToList();

            await ReloadVisitStats();
        }
        catch { /* Handle error */ }
        finally { _isLoading = false; }
    }

    private void ProcessCategories(List<PoiModel> pois)
    {
        var map = new Dictionary<string, int> { { "Nhà hàng", 0 }, { "Quán ăn", 0 }, { "Cafe", 0 }, { "Quán nhậu", 0 }, { "Khác", 0 } };
        foreach (var poi in pois)
        {
            var title = poi.Title?.ToLower() ?? "";
            if (title.Contains("nhà hàng") || title.Contains("restaurant")) map["Nhà hàng"]++;
            else if (title.Contains("cafe") || title.Contains("cà phê")) map["Cafe"]++;
            else if (title.Contains("nhậu") || title.Contains("bar")) map["Quán nhậu"]++;
            else if (title.Contains("quán") || title.Contains("ăn")) map["Quán ăn"]++;
            else map["Khác"]++;
        }
        _categoryStats = map.Where(x => x.Value > 0).OrderByDescending(x => x.Value).Select(x => (x.Key, x.Value)).ToList();
    }

    private async Task OnTimerElapsed()
    {
        await FetchActiveUsers();
        await FetchHeatmapData(); // <-- BỔ SUNG: Cập nhật lại bản đồ sau mỗi 5 giây
        await InvokeAsync(StateHasChanged);
    }

    private async Task FetchActiveUsers()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ActiveUserResponse>("api/heartbeat/active-users");
            if (response != null) activeUserCount = response.ActiveUsers;
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    // ---> BỔ SUNG: HÀM MỚI ĐỂ GỌI API VÀ VẼ BẢN ĐỒ HEATMAP
    private async Task FetchHeatmapData()
    {
        try
        {
            // ĐÃ DÙNG ĐƯỜNG DẪN TƯƠNG ĐỐI SIÊU TỐI ƯU
            var points = await Http.GetFromJsonAsync<double[][]>("api/heartbeat/heatmap-data");
            if (points != null)
            {
                await JSRuntime.InvokeVoidAsync("drawAdminHeatmap", "admin-heatmap", points);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi tải Heatmap: {ex.Message}");
        }
    }
    // <--- KẾT THÚC BỔ SUNG

    private async Task ReloadVisitStats()
    {
        _visitStats = await Http.GetFromJsonAsync<List<PoiVisitStatsModel>>("api/PoiVisit/stats") ?? new();
        _visitStats = _visitStats.OrderByDescending(x => x.TotalVisits).Take(10).ToList();
        _totalVisits = _visitStats.Sum(x => x.TotalVisits);
    }

    private double GetCategoryPercent(int count)
    {
        var max = _categoryStats.Any() ? _categoryStats.Max(x => x.Count) : 1;
        return (double)count / max * 100;
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

    public class ActiveUserResponse { public int ActiveUsers { get; set; } }
}